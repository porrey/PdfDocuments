<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<GeneratePackageOnBuild>true</GeneratePackageOnBuild>
		<PackageRequireLicenseAcceptance>true</PackageRequireLicenseAcceptance>
		<PackageLicenseUrl></PackageLicenseUrl>
		<Authors>Daniel M. Porrey</Authors>
		<Company>Daniel M. Porrey</Company>
		<Product></Product>
		<Copyright>Copyright © Daniel Porrey 2021-2026. All Rights Reserved.</Copyright>
		<Description>High level C# library for the easy creation of PDF documents using PdfSharp.</Description>
		<Version>10.2.2</Version>
		<FileVersion>10.2.2</FileVersion>
		<AssemblyVersion>10.2.2</AssemblyVersion>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<PackageProjectUrl>https://github.com/porrey/PdfDocuments</PackageProjectUrl>
		<RepositoryUrl>https://github.com/porrey/PdfDocuments</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PackageIcon>PdfDcouments.png</PackageIcon>
		<NeutralLanguage>en-US</NeutralLanguage>
		<PackageIconUrl></PackageIconUrl>
		<PublishRepositoryUrl>true</PublishRepositoryUrl>
		<EmbedUntrackedSources>true</EmbedUntrackedSources>
		<PublishRepositoryUrl>true</PublishRepositoryUrl>
		<EmbedUntrackedSources>true</EmbedUntrackedSources>
		<IncludeSymbols>true</IncludeSymbols>
		<SymbolPackageFormat>snupkg</SymbolPackageFormat>
		<ContinuousIntegrationBuild>true</ContinuousIntegrationBuild>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<PackageTags>pdf;document;barcode</PackageTags>
		<ImplicitUsings>enable</ImplicitUsings>
		<GenerateDocumentationFile>True</GenerateDocumentationFile>
		<DocumentationFile>XmlDocs\PdfDocuments.xml</DocumentationFile>
	</PropertyGroup>

	<ItemGroup>
	  <None Remove="XmlDocs\PdfDocuments.xml" />
	</ItemGroup>

	<ItemGroup>
	  <Content Include="XmlDocs\PdfDocuments.xml">
	    <CopyToOutputDirectory>Always</CopyToOutputDirectory>
	  </Content>
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.7" />
		<PackageReference Include="PDFsharp" Version="6.2.4" />
		<PackageReference Include="SixLabors.ImageSharp" Version="3.1.12" />
		<PackageReference Include="System.DisposableObject" Version="10.1.0" />
	</ItemGroup>

	<ItemGroup>
		<None Include="..\..\..\Images\PdfDcouments.png">
			<Pack>True</Pack>
			<PackagePath></PackagePath>
		</None>
		<None Include="..\..\..\README.md">
			<Pack>True</Pack>
			<PackagePath>\</PackagePath>
		</None>
	</ItemGroup>

	<ItemGroup>
	  <Content Update="C:\Users\Danie\.nuget\packages\system.disposableobject\10.1.0\contentFiles\any\net10.0\XmlDocs\System.DisposableObject.xml">
	    <CopyToOutputDirectory>Always</CopyToOutputDirectory>
	  </Content>
	</ItemGroup>

</Project>
